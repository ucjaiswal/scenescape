  {
    "test_name": "Vision_AI/SSCAPE/API/CAMERA/11: Update non existent camera",
    "test_steps": [
      {
        "step_name": "Attempt to update camera with numeric UID",
        "api": "camera",
        "method": "updateCamera",
        "request": {
          "UID": "123",
          "body": {
            "name": "Should_Fail",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "intrinsics": {
              "fx": 1000.0,
              "fy": 1000.0,
              "cx": 960.0,
              "cy": 540.0
            },
            "resolution": [1920, 1080]
          }
        },
        "expected_status": {
          "status_code": 404
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/CAMERA/12: Get camera by UID",
    "test_steps": [
      {
        "step_name": "Get camera by UID",
        "api": "camera",
        "method": "getCamera",
        "request": {
          "UID": "${CAMERA_UID_MINIMAL}"
        },
        "expected_status": {
          "status_code": 200
        },
        "expected_body": {
          "uid": "${CAMERA_UID_MINIMAL}",
          "name": "Camera_Partial_Update_No_Res",
          "intrinsics": {
            "fx": 1000.0,
            "fy": 1000.0,
            "cx": 960.0,
            "cy": 540.0
          },
          "transform_type": "3d-2d point correspondence",
          "translation": [0.0, 0.0, 0.0],
          "rotation": [-0.0, 0.0, 0.0],
          "scale": [1.0, 1.0, 1.0],
          "resolution": [640, 480],
          "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
          "cv_subsystem": "AUTO",
          "undistort": false,
          "modelconfig": "model_config.json",
          "use_camera_pipeline": false
        }
      }
    ]
  },
