  {
    "test_name": "Vision_AI/SSCAPE/API/SENSOR/13: Get sensor by UID",
    "test_steps": [
      {
        "step_name": "Get minimal sensor",
        "api": "sensor",
        "method": "getSensor",
        "request": {
          "UID": "${SENSOR_UID_MINIMAL}"
        },
        "expected_status": {
          "status_code": 200
        },
        "expected_body": {
          "uid": "${SENSOR_UID_MINIMAL}",
          "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
          "sensor_id": "sensor_minimal",
          "name": "sensor_minimal",
          "area": "circle",
          "radius": 2.5,
          "center": [3.81, 4.59],
          "translation": [3.81, 4.59, 0.0],
          "singleton_type": "environmental"
        }
      }
    ]
  },
