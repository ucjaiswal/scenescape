  {
    "test_name": "Vision_AI/SSCAPE/API/SCENE/01: Create scene with only required properties",
    "test_steps": [
      {
        "step_name": "Create Scene",
        "api": "scene",
        "method": "createScene",
        "request": {
          "body": {
            "name": "Scene1",
            "use_tracker": true,
            "output_lla": false
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "SCENE_UID": "uid"
        }
      }
    ]
  },
