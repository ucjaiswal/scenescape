[
  {
    "test_name": "Vision_AI/SSCAPE/API/SENSOR/01: Create sensor with valid required properties",
    "test_steps": [
      {
        "step_name": "Create minimal sensor",
        "api": "sensor",
        "method": "createSensor",
        "request": {
          "body": {
            "name": "sensor_minimal",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "sensor_id": "sensor_minimal",
            "area": "circle",
            "radius": 2.5,
            "center": [3.81, 4.59],
            "translation": [1, 1, 1]
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "SENSOR_UID_MINIMAL": "uid"
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/SENSOR/02: Create sensor with circle area",
    "test_steps": [
      {
        "step_name": "Create full sensor",
        "api": "sensor",
        "method": "createSensor",
        "request": {
          "body": {
            "name": "sensor_full",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "sensor_id": "sensor_full",
            "area": "circle",
            "radius": 2.5,
            "center": [3.81, 4.59],
            "translation": [1, 1, 1],
            "singleton_type": "attribute",
            "color_ranges": {
              "sectors": [
                {
                  "color": "green",
                  "color_min": 0
                },
                {
                  "color": "yellow",
                  "color_min": 2
                },
                {
                  "color": "red",
                  "color_min": 5
                }
              ],
              "range_max": 10
            }
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "SENSOR_UID_FULL": "uid"
        }
      }
    ]
  },
