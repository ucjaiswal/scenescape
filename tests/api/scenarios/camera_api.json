        }
      },
      {
        "step_name": "Delete camera created without intrinsics",
        "api": "camera",
        "method": "deleteCamera",
        "request": {
          "UID": "${CAMERA_UID_NO_INTRINSICS}"
        },
        "expected_status": {
          "status_code": 200
        }
      }
    ]
  },
