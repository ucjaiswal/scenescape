        "expected_status": {
          "status_code": 200
        }
      },
      {
        "step_name": "Verify minimal sensor is deleted",
        "api": "sensor",
        "method": "getSensor",
        "request": {
          "UID": "${SENSOR_UID_MINIMAL}"
        },
        "expected_status": {
          "status_code": 404
