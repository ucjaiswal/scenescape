[
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/01: Create user with only required properties",
    "test_steps": [
      {
        "step_name": "Create user",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "user",
            "password": "Password123!"
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "USER_NAME_MINIMAL": "username",
          "USER_ID": "uid"
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/02: Create user with full payload",
    "test_steps": [
      {
        "step_name": "Create user with all optional fields",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "user_full",
            "password": "FullPassword123!",
            "email": "user_full@example.com",
            "is_active": true,
            "is_staff": true,
            "is_superuser": false,
            "first_name": "John",
            "last_name": "Doe",
            "scene": "16fd2706-8baf-433b-82eb-8c7fada847da"
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "USER_NAME_FULL": "username",
          "USER_ID_FULL": "uid"
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/03: Create user Without required field username",
    "test_steps": [
      {
        "step_name": "Create user missing username",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "password": "Password123!"
          }
        },
        "expected_status": {
          "status_code": 400
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/04: Create user without required field password",
    "test_steps": [
      {
        "step_name": "Create user missing password",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "user_no_pass"
          }
        },
        "expected_status": {
          "status_code": 400
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/05: Create user with invalid email format",
    "test_steps": [
      {
        "step_name": "Create user with bad email",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "user_bad_email",
            "password": "Password123!",
            "email": "invalid-email"
          }
        },
        "expected_status": {
          "status_code": 400
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/06: Create user with duplicate Username",
    "test_steps": [
      {
        "step_name": "Create duplicate username",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "${USER_NAME_FULL}",
            "password": "AnotherPass123!"
          }
        },
        "expected_status": {
          "status_code": 400
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/07: Create user with invalid scene uid",
    "test_steps": [
      {
        "step_name": "Create user with invalid scene uid",
        "api": "user",
        "method": "createUser",
        "request": {
          "body": {
            "username": "invalid_scene",
            "password": "AnotherPass123!",
            "scene": "invalid-uuid"
          }
        },
        "expected_status": {
          "status_code": 400
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/08: Get existing user",
    "test_steps": [
      {
        "step_name": "Get user",
        "api": "user",
        "method": "getUser",
        "request": {
          "username": "${USER_NAME_MINIMAL}"
        },
        "expected_status": {
          "status_code": 200
        },
        "expected_body": {
          "uid": "${USER_ID}",
          "username": "${USER_NAME_MINIMAL}",
          "is_active": true,
          "is_staff": false,
          "is_superuser": false,
          "first_name": "",
          "last_name": "",
          "email": ""
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/USER/09: Get non existent user",
    "test_steps": [
      {
        "step_name": "Get user that does not exist",
        "api": "user",
        "method": "getUser",
        "request": {
          "username": "invalid_user"
        },
        "expected_status": {
          "status_code": 404
        }
      }
    ]
  },
