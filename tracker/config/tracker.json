{
  "infrastructure": {
    "mqtt": {
      "host": "broker.scenescape.intel.com",
      "port": 1883,
      "insecure": false,
      "tls": {
        "ca_cert_path": "/run/secrets/certs/scenescape-ca.pem",
        "verify_server": true
      }
    },
    "tracker": {
      "healthcheck": {
        "port": 8080
      }
    },
    "manager": {
      "url": "https://web.scenescape.intel.com",
      "auth_path": "/run/secrets/controller.auth"
    },
    "otlp": {
      "endpoint": "localhost:4317",
      "insecure": true
    }
  },
  "observability": {
    "logging": {
      "level": "info"
    },
    "metrics": {
      "enabled": false,
      "export_interval_s": 60
    },
    "tracing": {
      "enabled": false,
      "export_interval_s": 5
    }
  },
  "tracking": {
    "max_lag_s": 1.0,
    "time_chunking_rate_fps": 15,
    "max_workers": 50,
    "max_unreliable_time_s": 1.0,
    "non_measurement_time_dynamic_s": 0.8,
    "non_measurement_time_static_s": 1.6
  },
  "scenes": {
    "source": "api"
  }
}
