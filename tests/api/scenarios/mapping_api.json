[
  {
    "test_name": "Vision_AI/SSCAPE/API/MAPPING/01: Perform GLB reconstruction request with image",
    "test_steps": [
      {
        "step_name": "POST /reconstruction — upload image",
        "api": "mapping",
        "method": "performReconstruction",
        "request": {
          "body": {
            "images": ["test_media/atag-calib-demo-map.png"],
            "output_format": "glb",
            "mesh_type": "mesh",
            "use_keyframes": true
          }
        },
        "expected_status": {
          "status_code": 200
        },
        "save": {
          "IMAGE_REQUEST_ID": "request_id"
        },
        "validate": {
          "success": true,
          "state": "processing"
        }
      },
      {
        "step_name": "GET /reconstruction/status/{id} — poll until state == complete",
        "api": "mapping",
        "method": "getReconstructionStatus",
        "request": {
          "path_params": {
            "request_id": "${IMAGE_REQUEST_ID}"
          }
        },
        "expected_status": { "status_code": 200 },
        "poll": {
          "interval_s": 2,
          "timeout_s": 420,
          "until": { "state": "complete" },
          "fail_if": { "state": "failed" }
        },
        "validate": {
          "state": "complete"
        }
      }
    ]
  },
