  {
    "test_name": "Vision_AI/SSCAPE/API/SENSOR/15: Get all sensors",
    "test_steps": [
      {
        "step_name": "Get all sensors",
        "api": "sensor",
        "method": "getSensors",
        "request": {
          "filter": {
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c"
          }
        },
        "expected_status": {
          "status_code": 200
        },
        "expected_body": {
          "count": 2,
          "next": null,
          "previous": null,
          "results": [
            {
              "uid": "${SENSOR_UID_MINIMAL}",
              "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
              "sensor_id": "sensor_minimal",
              "name": "sensor_minimal",
              "area": "circle",
              "radius": 2.5,
              "center": [3.81, 4.59],
              "translation": [1, 1, 1],
              "singleton_type": "environmental"
            },
            {
              "uid": "${SENSOR_UID_FULL}",
              "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
              "sensor_id": "sensor_full",
              "name": "sensor_full",
              "area": "circle",
              "radius": 2.5,
              "center": [3.81, 4.59],
              "translation": [1, 1, 1],
              "singleton_type": "attribute"
            }
          ]
        }
      }
    ]
  },
