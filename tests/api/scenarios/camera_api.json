[
  {
    "test_name": "Vision_AI/SSCAPE/API/CAMERA/01: Create camera with only required properties",
    "test_steps": [
      {
        "step_name": "Create camera with minimal payload",
        "api": "camera",
        "method": "createCamera",
        "request": {
          "body": {
            "name": "Camera_Minimal",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "intrinsics": {
              "fx": 905,
              "fy": 905,
              "cx": 640,
              "cy": 360
            }
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "CAMERA_UID_MINIMAL": "uid"
        }
      }
    ]
  },
  {
    "test_name": "Vision_AI/SSCAPE/API/CAMERA/02: Create camera full valid payload",
    "test_steps": [
      {
        "step_name": "Create camera with full payload",
        "api": "camera",
        "method": "createCamera",
        "request": {
          "body": {
            "name": "Camera_Full",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "intrinsics": {
              "fx": 905,
              "fy": 905,
              "cx": 640,
              "cy": 360
            },
            "translation": [1, 1, 1],
            "rotation": [1, 1, 1],
            "scale": [1, 1, 1]
          }
        },
        "expected_status": {
          "status_code": 201
        },
        "save": {
          "CAMERA_UID_FULL": "uid"
        }
      }
    ]
  },
  {
