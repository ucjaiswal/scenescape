  {
    "test_name": "Vision_AI/SSCAPE/API/CAMERA/06: Update camera with minimal valid payload",
    "test_steps": [
      {
        "step_name": "Update camera with minimal payload",
        "api": "camera",
        "method": "updateCamera",
        "request": {
          "UID": "${CAMERA_UID_MINIMAL}",
          "body": {
            "name": "Camera_Minimal_Updated",
            "scene": "3bc091c7-e449-46a0-9540-29c499bca18c",
            "intrinsics": {
              "fx": 1100.0,
              "fy": 1100.0,
              "cx": 960.0,
              "cy": 540.0
            }
          }
        },
        "expected_status": {
          "status_code": 200
        }
      },
      {
        "step_name": "Verify camera was updated",
        "api": "camera",
        "method": "getCamera",
        "request": {
          "UID": "${CAMERA_UID_MINIMAL}"
        },
        "expected_status": {
          "status_code": 200
        },
        "validate": {
          "name": "Camera_Minimal_Updated"
        }
      }
    ]
  },
