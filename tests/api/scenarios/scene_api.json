    "test_name": "Vision_AI/SSCAPE/API/SCENE/20: Delete scene by UID",
    "test_steps": [
      {
        "step_name": "Delete Scene",
        "api": "scene",
        "method": "deleteScene",
        "request": {
          "UID": "${SCENE_UID}"
        },
        "expected_status": {
          "status_code": 200
