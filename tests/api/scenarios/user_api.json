  {
    "test_name": "Vision_AI/SSCAPE/API/USER/11: Update user profile fields",
    "test_steps": [
      {
        "step_name": "Update email, first_name, last_name",
        "api": "user",
        "method": "updateUser",
        "request": {
          "username": "${USER_NAME_MINIMAL}",
          "body": {
            "email": "updated@example.com",
            "first_name": "UpdatedFirst",
            "last_name": "UpdatedLast"
          }
        },
        "expected_status": {
          "status_code": 200
        }
      },
      {
        "step_name": "Validate updated fields",
        "api": "user",
        "method": "getUser",
        "request": {
          "username": "${USER_NAME_MINIMAL}"
        },
        "expected_status": {
          "status_code": 200
        },
        "validate": {
          "email": "updated@example.com",
          "first_name": "UpdatedFirst",
          "last_name": "UpdatedLast"
        }
      }
    ]
  },
